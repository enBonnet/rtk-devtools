{
  "name": "@rtk-devtools/core",
  "version": "0.2.0",
  "description": "Framework-agnostic core engine for RTK Devtools",
  "author": "Ender Bonnet (@enBonnet)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": ">=1.9.0",
    "redux": ">=4.2.0"
  },
  "peerDependenciesMeta": {
    "redux": {
      "optional": true
    }
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.2.0",
    "redux": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/enBonnet/rtk-devtools.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/enBonnet/rtk-devtools/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/enBonnet/rtk-devtools/issues"
  },
  "keywords": [
    "redux",
    "rtk",
    "redux-toolkit",
    "devtools",
    "rtk-query"
  ],
  "sideEffects": false
}
