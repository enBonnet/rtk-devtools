{
  "name": "@rtk-devtools/ui",
  "version": "0.4.0",
  "description": "UI components and panels for RTK Devtools",
  "author": "Ender Bonnet (@enBonnet)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@rtk-devtools/core": "workspace:*",
    "@tanstack/react-virtual": "^3.5.0",
    "goober": "^2.1.14"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/enBonnet/rtk-devtools.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/enBonnet/rtk-devtools/tree/main/packages/ui#readme",
  "bugs": {
    "url": "https://github.com/enBonnet/rtk-devtools/issues"
  },
  "keywords": [
    "redux",
    "rtk",
    "redux-toolkit",
    "devtools",
    "rtk-query",
    "react"
  ],
  "sideEffects": false
}
